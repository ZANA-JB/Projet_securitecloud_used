{
  "family": "eduscore-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<account-id>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<account-id>:role/eduscore-backend-task-role",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "639914974992.dkr.ecr.eu-west-1.amazonaws.com/eduscore-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "MODEL_S3_BUCKET", "value": "2ie-<groupe>-models" },
        { "name": "MODEL_S3_KEY", "value": "model.pkl" },
        { "name": "AWS_REGION", "value": "<region>" },
        { "name": "GOOGLE_CLIENT_ID", "value": "<client-id-google>" },
        { "name": "ADMIN_EMAILS", "value": "<emails-admin-separes-par-virgules>" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:ssm:<region>:<account-id>:parameter/eduscore/DATABASE_URL"
        },
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:ssm:<region>:<account-id>:parameter/eduscore/JWT_SECRET"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/eduscore-backend",
          "awslogs-region": "<region>",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -fsS http://localhost:8000/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}
