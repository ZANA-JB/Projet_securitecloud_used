            "image": "639914974992.dkr.ecr.eu-west-1.amazonaws.com/eduscore-backend:latest",
            "cpu": 0,
            "portMappings": [
                {
                    "name": "backend-port",
                    "containerPort": 8000,
                    "hostPort": 8000,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                { "name": "AWS_REGION", "value": "eu-west-1" },
                { "name": "DATABASE_URL", "value": "postgresql://postgres:KoneBakouan01@database-1.cby4yi2mm3xm.eu-west-1.rds.amazonaws.com:5432/postgres?sslmode=require" },
                { "name": "PORT", "value": "8000" },
                { "name": "JWT_SECRET", "value": "6b25d2da92bc9577b7ade335ca6971e06145ac7e90be67f7658f2914b7e3f42e" },
                { "name": "GOOGLE_CLIENT_ID", "value": "602206238775-5hibhdit41tsnetu45ca2o9077icblif.apps.googleusercontent.com" },
                { "name": "MODEL_S3_KEY", "value": "model.pkl" },
                { "name": "ADMIN_EMAILS", "value": "zanakone1205@gmail.com" },
                { "name": "MODEL_S3_BUCKET", "value": "2ie-bakouan01-models" }
            ],
            "logConfiguration": {
