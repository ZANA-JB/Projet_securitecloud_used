# --- Base de données ---
# Variables consommées par le service PostgreSQL de docker-compose.
# Si vous changez ces valeurs après un premier lancement Docker, exécutez :
#   docker compose down -v
# DATABASE_URL n'est volontairement pas listé :
#   - docker compose le construit vers postgres automatiquement
#   - en dev local sans Docker, le backend retombe sur sqlite (zéro install)
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=app

# --- Backend ---
MODEL_PATH=/app/models/model.pkl

# --- Modèle ML sur S3 (laisser vide en local pour utiliser le fallback MicroScore) ---
# MODEL_S3_BUCKET=2ie-groupeX-models
# MODEL_S3_KEY=model.pkl

# --- AWS (pour l'accès S3 en local depuis le backend) ---
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Authentification Google (espace admin) ---
# Client ID public — Google Cloud Console > APIs & Services > Credentials.
# Dans le client OAuth Web, ajouter exactement ces origins autorisées :
#   http://localhost:5173
#   http://127.0.0.1:5173   # optionnel si vous utilisez 127.0.0.1
# Ne pas mettre /login, ne pas ajouter de slash final.
# Le MEME client id doit aussi être renseigné dans VITE_GOOGLE_CLIENT_ID ci-dessous.
GOOGLE_CLIENT_ID=votre-client-id.apps.googleusercontent.com
# Secret de signature des JWT applicatifs — générer avec : openssl rand -hex 32
JWT_SECRET=changeme-generer-une-vraie-cle-aleatoire
# Emails autorisés à accéder à l'espace admin, séparés par des virgules
# (mettez vos vrais emails admin dans le .env, pas ici)
ADMIN_EMAILS=admin@example.com,autre-admin@example.com

# --- Frontend ---
VITE_API_URL=/api
# Client ID Google côté navigateur (identique à GOOGLE_CLIENT_ID ci-dessus)
VITE_GOOGLE_CLIENT_ID=votre-client-id.apps.googleusercontent.com

# --- CI/CD (configurer dans GitHub > Settings > Secrets) ---
# DOCKERHUB_USERNAME=votre-user-dockerhub
DOCKERHUB_TOKEN=dckr_pat_D5A6zH2gpcjZIYcFu1GhMID5ZtU
# AWS_ROLE_TO_ASSUME=arn:aws:iam::ACCOUNT:role/github-actions-deploy

# --- Scripts locaux de build/push (valeurs non secrètes) ---
DOCKERHUB_USERNAME=votre-user-dockerhub
AWS_ACCOUNT_ID=123456789012
# Token DockerHub Read & Write si vous voulez pousser avec le script local.
DOCKERHUB_TOKEN=
BACKEND_REPO=projet-cloud-backend
FRONTEND_REPO=projet-cloud-frontend
IMAGE_TAG=latest


